# Hugging Face token used for the Inference Providers router.
# Create one (free tier works) at https://huggingface.co/settings/tokens
HF_API_TOKEN=

# Optional overrides
# Comma-separated list of vision-language models to try in order.
# HF_VLM_MODELS=Qwen/Qwen3-VL-8B-Instruct,Qwen/Qwen3-VL-30B-A3B-Instruct,Qwen/Qwen2.5-VL-72B-Instruct
# HF_TIMEOUT=60
# FLASK_DEBUG=1
